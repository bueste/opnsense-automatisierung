<?xml version="1.0"?>
<model>
    <mount>//automatisierung</mount>
    <description>Automatisierung - Multi-OPNsense Management Plugin</description>
    <version>1.0.0</version>
    <items>
        <hosts>
            <host type="ArrayField">
                <enabled type="BooleanField">
                    <Default>1</Default>
                    <Required>Y</Required>
                </enabled>
                <name type="TextField">
                    <Required>Y</Required>
                    <mask>/^.{1,64}$/</mask>
                    <ValidationMessage>Name darf maximal 64 Zeichen enthalten.</ValidationMessage>
                </name>
                <url type="TextField">
                    <Required>Y</Required>
                    <mask>/^https?:\/\/.+/</mask>
                    <ValidationMessage>Bitte eine gültige URL eingeben (http:// oder https://).</ValidationMessage>
                </url>
                <api_key type="TextField">
                    <Required>Y</Required>
                    <mask>/^[^\s]{1,512}$/</mask>
                    <ValidationMessage>API Key darf keine Leerzeichen enthalten.</ValidationMessage>
                </api_key>
                <api_secret type="TextField">
                    <Required>Y</Required>
                    <mask>/^[^\s]{1,512}$/</mask>
                    <ValidationMessage>API Secret darf keine Leerzeichen enthalten.</ValidationMessage>
                </api_secret>
                <auto_update_opnsense type="BooleanField">
                    <Default>0</Default>
                </auto_update_opnsense>
                <auto_update_za type="BooleanField">
                    <Default>0</Default>
                </auto_update_za>
                <za_watchdog type="BooleanField">
                    <Default>0</Default>
                </za_watchdog>
                <skip_verify_tls type="BooleanField">
                    <Default>0</Default>
                </skip_verify_tls>
                <backup_enabled type="BooleanField">
                    <Default>0</Default>
                </backup_enabled>
            </host>
        </hosts>
        <general>
            <update_hour type="IntegerField">
                <Default>3</Default>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>23</MaximumValue>
            </update_hour>
            <update_minute type="IntegerField">
                <Default>0</Default>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>59</MaximumValue>
            </update_minute>
            <update_days type="TextField">
                <Default>*</Default>
                <mask>/^[\d,\*\-\/]+$/</mask>
                <ValidationMessage>Ungültiger Cron-Ausdruck für Wochentage.</ValidationMessage>
            </update_days>
            <za_check_interval type="TextField">
                <Default>15</Default>
                <mask>/^(5|10|15|30|60)$/</mask>
                <ValidationMessage>Ungültiges Intervall. Erlaubt: 5, 10, 15, 30, 60.</ValidationMessage>
            </za_check_interval>
            <auto_update_enabled type="BooleanField">
                <Default>0</Default>
            </auto_update_enabled>
            <za_watchdog_enabled type="BooleanField">
                <Default>0</Default>
            </za_watchdog_enabled>
            <backup_enabled type="BooleanField">
                <Default>0</Default>
            </backup_enabled>
            <backup_hour type="IntegerField">
                <Default>2</Default>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>23</MaximumValue>
            </backup_hour>
            <backup_minute type="IntegerField">
                <Default>0</Default>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>59</MaximumValue>
            </backup_minute>
            <backup_days type="TextField">
                <Default>*</Default>
                <mask>/^[\d,\*\-\/]+$/</mask>
                <ValidationMessage>Ungültiger Cron-Ausdruck für Wochentage.</ValidationMessage>
            </backup_days>
            <backup_retention_days type="IntegerField">
                <Default>30</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>365</MaximumValue>
            </backup_retention_days>
            <!-- Notifications -->
            <notify_enabled type="BooleanField">
                <Default>0</Default>
            </notify_enabled>
            <notify_telegram_enabled type="BooleanField">
                <Default>0</Default>
            </notify_telegram_enabled>
            <notify_telegram_token type="TextField">
                <mask>/^[^\s]{0,128}$/</mask>
                <ValidationMessage>Ungültiges Telegram Bot-Token.</ValidationMessage>
            </notify_telegram_token>
            <notify_telegram_chatid type="TextField">
                <mask>/^[\w\-]{0,64}$/</mask>
                <ValidationMessage>Ungültige Telegram Chat-ID.</ValidationMessage>
            </notify_telegram_chatid>
            <notify_pushover_enabled type="BooleanField">
                <Default>0</Default>
            </notify_pushover_enabled>
            <notify_pushover_token type="TextField">
                <mask>/^[\w]{0,40}$/</mask>
                <ValidationMessage>Ungültiges Pushover App-Token.</ValidationMessage>
            </notify_pushover_token>
            <notify_pushover_user type="TextField">
                <mask>/^[\w]{0,40}$/</mask>
                <ValidationMessage>Ungültiger Pushover User-Key.</ValidationMessage>
            </notify_pushover_user>
            <notify_matrix_enabled type="BooleanField">
                <Default>0</Default>
            </notify_matrix_enabled>
            <notify_matrix_homeserver type="TextField">
                <mask>/^(https?:\/\/.+)?$/</mask>
                <ValidationMessage>Homeserver muss eine URL sein (https://...).</ValidationMessage>
            </notify_matrix_homeserver>
            <notify_matrix_token type="TextField">
                <mask>/^[^\s]{0,256}$/</mask>
            </notify_matrix_token>
            <notify_matrix_room type="TextField">
                <mask>/^[^\s]{0,128}$/</mask>
                <ValidationMessage>Ungültige Matrix Room-ID (z.B. !abc:server.tld).</ValidationMessage>
            </notify_matrix_room>
            <!-- Self-Healing (separate cron; every action OFF by default, opt-in) -->
            <heal_check_interval type="TextField">
                <Default>15</Default>
                <mask>/^(5|10|15|30|60)$/</mask>
                <ValidationMessage>Ungültiges Intervall. Erlaubt: 5, 10, 15, 30, 60.</ValidationMessage>
            </heal_check_interval>
            <heal_ram_enabled type="BooleanField">
                <Default>0</Default>
            </heal_ram_enabled>
            <heal_ram_threshold type="IntegerField">
                <Default>85</Default>
                <MinimumValue>50</MinimumValue>
                <MaximumValue>99</MaximumValue>
            </heal_ram_threshold>
            <heal_disk_enabled type="BooleanField">
                <Default>0</Default>
            </heal_disk_enabled>
            <heal_disk_threshold type="IntegerField">
                <Default>90</Default>
                <MinimumValue>50</MinimumValue>
                <MaximumValue>99</MaximumValue>
            </heal_disk_threshold>
            <heal_ifreset_enabled type="BooleanField">
                <Default>0</Default>
            </heal_ifreset_enabled>
            <heal_ifreset_target type="TextField">
                <mask>/^[\w\.\-:]{0,128}$/</mask>
                <ValidationMessage>Ungültiges Probe-Ziel (IP oder Hostname).</ValidationMessage>
            </heal_ifreset_target>
        </general>
    </items>
</model>
